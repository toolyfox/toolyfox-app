generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  plan      String   @default("free")
  logoUrl   String?  @map("logo_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memberships  Membership[]
  websites     Website[]
  reports      Report[]
  apiKeys      ApiKey[]
  subscriptions Subscription[]
  auditLogs    AuditLog[]
  invitations  Invitation[]

  @@map("organizations")
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  name      String
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")

  memberships Membership[]
  auditLogs   AuditLog[]
  invitations Invitation[]

  @@map("users")
}

model Membership {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  role      String   @default("member")
  createdAt DateTime @default(now()) @map("created_at")

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@map("memberships")
}

model Invitation {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  email     String
  role      String   @default("member")
  token     String   @unique
  invitedBy String?  @map("invited_by") @db.Uuid
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  inviter  User?        @relation(fields: [invitedBy], references: [id])

  @@map("invitations")
}

model Website {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  url       String
  name      String
  domain    String
  isActive  Boolean  @default(true) @map("is_active")
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org        Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  scans      Scan[]
  trustScore TrustScore?
  alerts     Alert[]
  reports    Report[]

  @@map("websites")
}

model Scan {
  id          String    @id @default(uuid()) @db.Uuid
  websiteId   String    @map("website_id") @db.Uuid
  type        String
  status      String    @default("pending")
  score       Decimal?  @db.Decimal(5, 2)
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  website Website       @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  results ScanResult[]

  @@index([websiteId])
  @@index([status])
  @@map("scans")
}

model ScanResult {
  id          String   @id @default(uuid()) @db.Uuid
  scanId      String   @map("scan_id") @db.Uuid
  category    String
  severity    String
  title       String
  description String
  remediation String?
  rawData     Json?    @map("raw_data")
  createdAt   DateTime @default(now()) @map("created_at")

  scan Scan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([scanId])
  @@map("scan_results")
}

model TrustScore {
  id           String   @id @default(uuid()) @db.Uuid
  websiteId    String   @unique @map("website_id") @db.Uuid
  overall      Decimal  @db.Decimal(5, 2)
  security     Decimal  @db.Decimal(5, 2)
  performance  Decimal  @db.Decimal(5, 2)
  seo          Decimal  @db.Decimal(5, 2)
  dns          Decimal  @db.Decimal(5, 2)
  ssl          Decimal  @db.Decimal(5, 2)
  uptime       Decimal  @db.Decimal(5, 2)
  calculatedAt DateTime @default(now()) @map("calculated_at")

  website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@map("trust_scores")
}

model Report {
  id           String   @id @default(uuid()) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  websiteId    String   @map("website_id") @db.Uuid
  type         String
  status       String   @default("generating")
  pdfUrl       String?  @map("pdf_url")
  isWhiteLabel Boolean  @default(false) @map("is_white_label")
  branding     Json?    @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  website Website      @relation(fields: [websiteId], references: [id])

  @@index([orgId])
  @@index([websiteId])
  @@map("reports")
}

model Alert {
  id        String   @id @default(uuid()) @db.Uuid
  websiteId String   @map("website_id") @db.Uuid
  type      String
  channel   String
  recipient String
  isEnabled Boolean  @default(true) @map("is_enabled")
  createdAt DateTime @default(now()) @map("created_at")

  website Website       @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  events  AlertEvent[]

  @@index([websiteId])
  @@map("alerts")
}

model AlertEvent {
  id          String   @id @default(uuid()) @db.Uuid
  alertId     String   @map("alert_id") @db.Uuid
  triggeredAt DateTime @default(now()) @map("triggered_at")
  message     String
  sentAt      DateTime? @map("sent_at")
  status      String   @default("pending")

  alert Alert @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@index([alertId])
  @@map("alert_events")
}

model ApiKey {
  id         String    @id @default(uuid()) @db.Uuid
  orgId      String    @map("org_id") @db.Uuid
  name       String
  key        String    @unique
  scopes     String[]
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("api_keys")
}

model Subscription {
  id                   String   @id @default(uuid()) @db.Uuid
  orgId                String   @unique @map("org_id") @db.Uuid
  stripeCustomerId     String   @map("stripe_customer_id")
  stripeSubscriptionId String   @map("stripe_subscription_id")
  planId               String   @map("plan_id")
  status               String
  currentPeriodStart   DateTime @map("current_period_start")
  currentPeriodEnd     DateTime @map("current_period_end")
  createdAt            DateTime @default(now()) @map("created_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String
  resource  String
  details   Json?
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User?        @relation(fields: [userId], references: [id])

  @@index([orgId])
  @@index([createdAt])
  @@map("audit_logs")
}
